# CryptoTracker Pro - 环境变量配置

# 飞书 Webhook（必填）
# 飞书群 -> 设置 -> 机器人 -> 添加机器人 -> 复制 Webhook 地址
FEISHU_WEBHOOK=

# 企业微信 Webhook（可选）
# 企业微信群 -> 右上角设置 -> 群机器人 -> 添加机器人 -> 复制 Webhook 地址
WECHAT_WEBHOOK=

# Flask 配置
SECRET_KEY=crypto-tracker-secret-key
PORT=5000

# 代理配置（可选）
# 如果需要通过代理访问外网（如 Binance API），设置以下环境变量：
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# USE_PROXY=true

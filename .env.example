# CryptoTracker Pro - 环境变量配置

# 飞书 Webhook（推荐）
# 飞书群 -> 设置 -> 机器人 -> 添加机器人 -> 复制 Webhook 地址
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 企业微信 Webhook
# 企业微信群 -> 右上角设置 -> 群机器人 -> 添加机器人 -> 复制 Webhook 地址
WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Flask 配置
SECRET_KEY=your-secret-key-here
PORT=5000
